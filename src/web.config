<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        
        <!-- Usa "Auto" per preservare eventuali JSON 404 generati dall'API -->
        <httpErrors errorMode="Custom" existingResponse="Auto">
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
        </httpErrors>

        <rewrite>
            <rules>
                
                <!-- 1. Delega la cartella API al suo web.config interno -->
                <rule name="Ignore API Directory" stopProcessing="true">
                    <match url="^api/.*" ignoreCase="true" />
                    <action type="None" />
                </rule>

                <!-- 2. (Opzionale) Esplicita a IIS di servire i file esistenti. 
                     In IIS è ridondante perché lo fa già di natura, ma lasciarlo 
                     è innocuo e ricalca perfettamente la tua vecchia logica Apache -->
                <rule name="Serve Existing Files and Directories" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions logicalGrouping="MatchAny">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
                    </conditions>
                    <action type="None" />
                </rule>

            </rules>
        </rewrite>
        
    </system.webServer>
</configuration>