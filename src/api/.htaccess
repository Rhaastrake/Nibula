<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/

    # Non processare file reali (immagini, vendor, ecc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tutto il resto va a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>